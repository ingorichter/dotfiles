# load machine specific configuration
if [ -e "${MACHINE_CONFIG_FILE}" ]; then
  source "${MACHINE_CONFIG_FILE}"
fi

# Alias definition
for alias in $(find ~/.alias.d/ -type f -not -name .DS_Store)
do
    source "$alias"
done

# After path_helper: restore priority. OpenJDK first (same as zshenv), then Homebrew.
if [ -n "$HOMEBREW_PREFIX" ]; then
    _JDK_BIN="${HOMEBREW_PREFIX}/opt/openjdk/bin"
    if [ -d "$_JDK_BIN" ]; then
        export PATH="${_JDK_BIN}:${HOMEBREW_PREFIX}/bin:${HOMEBREW_PREFIX}/sbin:${HOMEBREW_PREFIX}/opt/curl/bin:${PATH}"
    else
        export PATH="${HOMEBREW_PREFIX}/bin:${HOMEBREW_PREFIX}/sbin:${HOMEBREW_PREFIX}/opt/curl/bin:${PATH}"
    fi
    unset _JDK_BIN
fi

# path_helper + zshenv both contribute; drop duplicate entries
dedupe_path

# Added by swiftly
if [ -f "$HOME/.swiftly/env.sh" ]; then
    . "$HOME/.swiftly/env.sh"
fi
